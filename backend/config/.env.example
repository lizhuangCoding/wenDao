# Server
SERVER_PORT=8089
SERVER_MODE=debug

# Database
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=change-me
DB_NAME=wendao

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# Redis Vector
REDIS_VECTOR_HOST=localhost
REDIS_VECTOR_PORT=6379
REDIS_VECTOR_PASSWORD=

# JWT
JWT_SECRET=change-me-to-a-long-random-secret

# Upload / Site / Log
UPLOAD_PATH=./uploads
SITE_URL=http://localhost:3000
LOG_FORMAT=console
LOG_OUTPUT=log/

# GitHub OAuth
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_CALLBACK_URL=http://localhost:8089/api/auth/github/callback

# Doubao / AI
DOUBAO_API_KEY=
DOUBAO_ENDPOINT=https://ark.cn-beijing.volces.com/api/v3
DOUBAO_CHAT_MODEL=doubao-1.5-pro-32k-250115
DOUBAO_EMBEDDING_MODEL=doubao-embedding-large-text-240915

# Research
RESEARCH_ENDPOINT=https://google.serper.dev/search
RESEARCH_API_KEY=

# Admin bootstrap (only pass these when running scripts/init_admin.go or /app/wendao-init-admin)
# ADMIN_EMAIL=your-email@example.com
# ADMIN_USERNAME=lizhuang
# ADMIN_PASSWORD=change-me
