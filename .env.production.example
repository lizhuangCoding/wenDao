COMPOSE_PROJECT_NAME=wendao

# Public entrypoint. PUBLIC_DOMAIN is used by Caddy; SITE_URL is used by the app.
PUBLIC_DOMAIN=example.com
SITE_URL=https://example.com
VITE_API_BASE_URL=/api

# Database.
DB_NAME=wendao
DB_USER=wendao
DB_PASSWORD=change-me-database-password
MYSQL_ROOT_PASSWORD=change-me-root-password

# Redis / Redis Stack.
REDIS_PASSWORD=change-me-redis-password

# Auth.
JWT_SECRET=change-me-to-a-long-random-secret-at-least-32-chars

# GitHub OAuth. Leave blank if you do not use GitHub login.
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_CALLBACK_URL=https://example.com/api/auth/github/callback

# Doubao / AI. Leave blank to run without AI features.
DOUBAO_API_KEY=
DOUBAO_ENDPOINT=https://ark.cn-beijing.volces.com/api/v3
DOUBAO_CHAT_MODEL=doubao-1.5-pro-32k-250115
DOUBAO_EMBEDDING_MODEL=doubao-embedding-large-text-240915

# Optional web research endpoint.
RESEARCH_ENDPOINT=https://google.serper.dev/search
RESEARCH_API_KEY=

# Admin bootstrap. Keep real passwords only in .env.production.
ADMIN_EMAIL=
ADMIN_USERNAME=
ADMIN_PASSWORD=

TZ=Asia/Shanghai
